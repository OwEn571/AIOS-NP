ZH_API_KEY=
TAVILY_API_KEY=

OPENAI_API_KEY=
AIOS_LLM_MODEL=qwen3-max
AIOS_LLM_BACKEND=openai
AIOS_LLM_BASE_URL=https://api.qhaigc.net/v1
AIOS_REQUIRE_KERNEL=false

# 如果你把模型或服务起在别的地址，可改这里
CEREBRUM_KERNEL_URL=http://localhost:8001
AIOS_NP_DATA_DIR=/home/ubuntu/owen/AIOS-NP
AIOS_ARTIFACT_STORE_BACKEND=aios
AIOS_ARTIFACT_AGENT_NAME=news_artifact_store
AIOS_ARTIFACT_STORE_FALLBACK_LOCAL=true
AIOS_ARTIFACT_AUTO_MOUNT=true
AIOS_WORKFLOW_MEMORY_ENABLED=true
AIOS_WORKFLOW_MEMORY_AGENT_NAME=news_workflow_memory
AIOS_WORKFLOW_MEMORY_TIMEOUT_SECONDS=8
AIOS_MEMORY_COLLECTION_NAME=memories_localhash_v1
AIOS_MEMORY_CHROMA_DIR=/home/ubuntu/owen/data/aios-np-memory-chroma

NEWS_SERVICE_HOST=0.0.0.0
NEWS_SERVICE_PORT=8010
NEWS_AUTO_RUN_ENABLED=false
NEWS_AUTO_RUN_TIME=08:30
NEWS_AUTO_RUN_MODE=serial
NEWS_AUTO_RUN_ON_START=false
